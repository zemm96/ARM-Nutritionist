               </property>
               <property name="styleSheet">
                <string notr="true">QSpinBox {
    background-color: #FFFFFF;
    border: 1.5px solid #D0DECE;
    border-radius: 8px;
    padding: 8px 12px;
    font-family: &quot;Segoe UI&quot;, Arial, sans-serif;
    font-size: 14px;
    color: #1A1A1A;
    min-height: 20px;
    min-width: 120px;
    max-width: 150px;
}

QSpinBox:focus {
    border: 1.5px solid #2D6A30;
}

/* Кнопки − и + */
QSpinBox::up-button,
QSpinBox::down-button {
    width: 24px;
    border: none;
    background-color: transparent;
    border-radius: 4px;
    subcontrol-origin: border;
}

QSpinBox::up-button {
    subcontrol-position: right;
    right: 1px;
}

QSpinBox::down-button {
    subcontrol-position: left;
    left: 1px;
}

QSpinBox::up-button:hover,
QSpinBox::down-button:hover {
    background-color: #EDF4EB;
}

/* Стрелки — переопределяем системные иконки */
QSpinBox::up-arrow {
    image: none;
    width: 0; height: 0;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-bottom: 5px solid #5A6B5A;
}
QSpinBox::down-arrow {
    image: none;
    width: 0; height: 0;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-top: 5px solid #5A6B5A;
}
</string>
